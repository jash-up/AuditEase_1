{
  "name": "auditease",
  "version": "1.0.0",
  "description": "Professional audit document management application",
  "main": "backend/server.js",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "nodemon backend/server.js",
    "add-user": "node scripts/add-user.js",
    "delete-user": "node scripts/delete-user.js",
    "change-password": "node scripts/change-password.js",
    "update-role": "node scripts/update-role.js",
    "list-users": "node scripts/list-users.js",
    "postinstall": "echo 'Install complete. If bcrypt or better-sqlite3 failed to build, see README.md Troubleshooting section.'"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^12.10.1",
    "docx": "^9.7.1",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.2.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "overrides": {
    "tar": "^7.5.16"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "allowScripts": {
    "bcrypt@5.1.1": true,
    "better-sqlite3@12.11.1": true
  }
}
